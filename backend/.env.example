# Core
NODE_ENV=development
PORT=3000

# PostgreSQL database
DATABASE_URL=postgresql://perfume_gpt_user:strong_password@localhost:5432/perfume_gpt_db?schema=public

# Redis (cache, rate limiting, queues)
REDIS_URL=redis://localhost:6379

# JWT configuration
JWT_ACCESS_SECRET=your-strong-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-strong-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# OAuth2 providers
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google/callback

OAUTH_FACEBOOK_CLIENT_ID=your-facebook-app-id
OAUTH_FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
OAUTH_FACEBOOK_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/facebook/callback

# xAI / AI provider
XAI_API_KEY=your-xai-api-key
XAI_BASE_URL=https://api.x.ai/v1

# Payment gateways
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
PAYOS_RETURN_URL=http://localhost:3001/payment/payos/return
PAYOS_CANCEL_URL=http://localhost:3001/payment/payos/cancel

# VietQR
VIETQR_API_KEY=your-vietqr-api-key
VIETQR_CLIENT_ID=your-vietqr-client-id
VIETQR_ACCOUNT_NO=your-bank-account-number
VIETQR_ACCOUNT_NAME=your-account-name
VIETQR_BANK_CODE=your-bank-code

# Shipping providers
SHIPPING_GHN_TOKEN=your-ghn-token
SHIPPING_GHN_SHOP_ID=your-ghn-shop-id
SHIPPING_GHN_FROM_DISTRICT_ID=1454
SHIPPING_GHN_FROM_WARD_CODE=21012
SHIPPING_GHN_RETURN_PHONE=0987654321
SHIPPING_GHN_RETURN_ADDRESS=123 Ly Tu Trong, Quan 1, HCM

SHIPPING_GHTK_TOKEN=your-ghtk-token

# Email / SMS / Notification
MAIL_FROM=no-reply@perfume-gpt.local
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your-smtp-username
MAIL_PASSWORD=your-smtp-password

SMS_PROVIDER_API_KEY=your-sms-provider-api-key

# Frontend URLs
WEB_APP_URL=http://localhost:3001
MOBILE_APP_URL=http://localhost:3002

# Logging
LOG_LEVEL=debug

# SMTP 
SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Perfume Sales" <no-reply@perfumesales.com>

# GHN API
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
# GHN_API_URL=https://online-gateway.ghn.vn/shiip/public-api/v2
GHN_TOKEN=
GHN_SHOP_ID=
# Shop address (for Create Order)
GHN_RETURN_PHONE=
GHN_RETURN_ADDRESS=123 Nguyễn Huệ, Q1
GHN_RETURN_DISTRICT_ID=1442
GHN_RETURN_WARD_CODE=20201